# Example environment variables for TradingAgents automation
# Append these to the repo-root .env file and fill in your credentials

# Telegram Bot Token
# Create via BotFather (/newbot) on Telegram
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID
# Send a message to your bot, then visit:
# https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
# to find the chat_id in the response
TELEGRAM_CHAT_ID=

# Gmail address for email notifications
# Used by the email notification system
GMAIL_ADDRESS=

# Gmail App Password
# Requires 2-Step Verification enabled.
# Create at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# Local models via Ollama (omit these to use OpenAI via OPENAI_API_KEY).
# See automation/SETUP.md for the full setup.
TRADINGAGENTS_LLM_PROVIDER=ollama
TRADINGAGENTS_DEEP_THINK_LLM=qwen3:8b
TRADINGAGENTS_QUICK_THINK_LLM=qwen3:8b

# --- On-demand Telegram bot + hosted reports (automation/service.py) ---

# Invite code. People send "/start <code>" in Telegram to unlock the bot;
# unlocked users are remembered permanently in the local SQLite allowlist.
# Pick any hard-to-guess string and share it only with people you invite.
TELEGRAM_INVITE_CODE=

# Public HTTPS base URL where hosted reports are reachable, e.g. the
# hostname of your Cloudflare Tunnel (see automation/linux/cloudflared.service).
# Report links are built as "<this>/report/<id>?token=<user_token>".
REPORTS_PUBLIC_BASE_URL=

# Secret key used to sign report-link tokens (HMAC, via itsdangerous).
# Generate once with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Rotating this immediately invalidates every outstanding report link.
REPORTS_SIGNING_KEY=

# Maximum on-demand analyses per user per day.
BOT_DAILY_CAP=5

# Analysis preset used for on-demand requests (see automation/settings.py
# PRESETS). "cost_saver" is recommended for a shared Ollama host.
BOT_PRESET=cost_saver

# Host/port for the local report web server (FastAPI/uvicorn). Keep this
# bound to 127.0.0.1 — Cloudflare Tunnel is the public ingress.
REPORTS_WEB_HOST=127.0.0.1
REPORTS_WEB_PORT=8787

# Optional SQLite database path. Defaults to automation/logs/service.db.
BOT_DB_PATH=

# Telegram numeric user ID of the service owner/admin. Enables the
# owner-only "/status" command. Find your ID by messaging @userinfobot on
# Telegram.
BOT_ADMIN_USER_ID=

# How long (seconds) a completed analysis is reused for repeat requests of
# the same ticker/date/preset before re-running the pipeline. Default 7200
# (2h) - safe for a daily-rating tool; shorten during volatile periods or
# set to 0 to disable caching entirely.
REPORT_CACHE_TTL_SECONDS=7200
